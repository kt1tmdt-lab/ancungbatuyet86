# Copy to .env and set values.
# Local Postgres example:
# DATABASE_URL="postgresql://postgres:12345@localhost:5432/acbt_db?schema=public"
#
# Hosted Postgres example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"
DATABASE_URL=""
JWT_SECRET="change-this-secret"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# VPS local uploads
# Development default: leave blank to use ./public/uploads and /uploads
# Production example:
# UPLOAD_DIR="/var/www/acbt-uploads"
# UPLOAD_PUBLIC_URL="https://your-domain.com/uploads"
UPLOAD_DIR=""
UPLOAD_PUBLIC_URL=""
UPLOAD_MAX_MB="50"
